# =============================================================================
# SwingCue — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# =============================================================================

# Supabase project URL — found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — NEVER expose to the browser.
# Used only in server-side API routes for privileged write operations.
SUPABASE_SERVICE_ROLE_KEY=
